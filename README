## 🗄️ Database
CREATE DATABASE BioskopDB;
GO

USE BioskopDB;
GO

CREATE TABLE [User] (
    user_id INT IDENTITY(1,1) PRIMARY KEY,
    nama VARCHAR(100),
    email VARCHAR(100) UNIQUE,
    password VARCHAR(100),
    role VARCHAR(20) -- Customer, Admin, Manager
);

CREATE TABLE Film (
    film_id INT IDENTITY(1,1) PRIMARY KEY,
    judul VARCHAR(100),
    genre VARCHAR(50),
    durasi INT
);

CREATE TABLE Studio (
    studio_id INT IDENTITY(1,1) PRIMARY KEY,
    nama_studio VARCHAR(50),
    kapasitas INT
);

CREATE TABLE Kursi (
    kursi_id INT IDENTITY(1,1) PRIMARY KEY,
    studio_id INT,
    nomor_kursi VARCHAR(10),

    FOREIGN KEY (studio_id) REFERENCES Studio(studio_id)
);

CREATE TABLE Jadwal (
    jadwal_id INT IDENTITY(1,1) PRIMARY KEY,
    film_id INT,
    studio_id INT,
    tanggal DATE,
    jam TIME,

    FOREIGN KEY (film_id) REFERENCES Film(film_id),
    FOREIGN KEY (studio_id) REFERENCES Studio(studio_id)
);

CREATE TABLE Tiket (
    tiket_id INT IDENTITY(1,1) PRIMARY KEY,
    jadwal_id INT,
    kursi_id INT,
    user_id INT,
    harga INT,
    status VARCHAR(50),

    FOREIGN KEY (jadwal_id) REFERENCES Jadwal(jadwal_id),
    FOREIGN KEY (kursi_id) REFERENCES Kursi(kursi_id),
    FOREIGN KEY (user_id) REFERENCES [User](user_id)
);

CREATE TABLE Pembayaran (
    pembayaran_id INT IDENTITY(1,1) PRIMARY KEY,
    tiket_id INT UNIQUE,
    metode VARCHAR(50),
    status VARCHAR(50),
    jumlah INT,

    FOREIGN KEY (tiket_id) REFERENCES Tiket(tiket_id)
);


Jadwal (
    jadwal_id INT IDENTITY PRIMARY KEY,
    film_id INT,
    tanggal DATETIME
)

