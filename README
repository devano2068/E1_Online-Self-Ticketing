SELECT Jadwal.jadwal_id, Film.judul + ' - ' + CONVERT(varchar, Jadwal.tanggal) AS tampil
FROM Jadwal
JOIN Film ON Film.film_id = Jadwal.film_id

SELECT Film.judul, Jadwal.tanggal
FROM Jadwal
INNER JOIN Film ON Film.film_id = Jadwal.film_id

SELECT Film.judul,
       COUNT(Tiket.tiket_id) AS total_tiket,
       SUM(Tiket.harga) AS total_pendapatan
FROM Tiket
JOIN Jadwal ON Tiket.jadwal_id = Jadwal.jadwal_id
JOIN Film ON Jadwal.film_id = Film.film_id
WHERE Tiket.status = 'Paid'
GROUP BY Film.judul




SELECT Film.judul,
       COUNT(Tiket.tiket_id) AS total_tiket,
       SUM(Tiket.harga) AS total_pendapatan
FROM Tiket
JOIN Jadwal ON Tiket.jadwal_id = Jadwal.jadwal_id
JOIN Film ON Jadwal.film_id = Film.film_id
WHERE Tiket.status = 'Paid'
GROUP BY Film.judul

SELECT * FROM Tiket;

UPDATE Tiket
SET status = 'Paid'
WHERE tiket_id = @id;

UPDATE Tiket
SET status = 'Paid'
WHERE tiket_id = 1;

